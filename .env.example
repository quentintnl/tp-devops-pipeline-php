# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — copie ce fichier en `.env` et adapte les valeurs.
# AUCUN secret réel ici : ce fichier est committé, `.env` ne l'est pas (.gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# --- Base de données (MariaDB) ---
# Hôte = nom du service Docker sur le réseau `backend` (pas localhost).
DB_HOST=db
# Port interne MariaDB (NON exposé sur l'hôte — cf. isolation réseau).
DB_PORT=3306
# Nom de la base applicative (créée au 1er run via docker-entrypoint-initdb.d).
DB_NAME=guestbook
# Utilisateur applicatif (droits limités à la base ci-dessus).
DB_USER=guestbook
# Mot de passe de l'utilisateur applicatif — à remplacer par une vraie valeur dans .env.
DB_PASSWORD=change-me-app
# Mot de passe root MariaDB — utilisé par l'image pour l'init — à remplacer dans .env.
DB_ROOT_PASSWORD=change-me-root

# --- Cache (Redis) ---
# Hôte = nom du service Docker sur le réseau `backend`.
REDIS_HOST=cache
# Port interne Redis (NON exposé sur l'hôte).
REDIS_PORT=6379

# --- Application ---
# Port HTTP publié par le service `web` (nginx) sur l'hôte ; le reverse-proxy forward dessus.
APP_PORT=8080
